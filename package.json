{
  "name": "resume",
  "version": "1.0.0",
  "author": "kanade0404 <melty0404@gmail.com>",
  "devDependencies": {
    "fixpack": "4.0.0",
    "md-to-pdf": "5.2.5",
    "rulesync": "9.6.3",
    "textlint": "15.7.1",
    "textlint-filter-rule-allowlist": "4.0.0",
    "textlint-rule-preset-ja-spacing": "3.0.2",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "textlint-rule-spellcheck-tech-word": "5.0.0"
  },
  "license": "MIT",
  "main": "index.js",
  "repository": "git@github.com:kanade0404/resume.git",
  "scripts": {
    "fix": "fixpack",
    "generate": "./convert.sh",
    "lint": "textlint *.md",
    "lint:fix": "textlint --fix *.md",
    "rulesync:check": "rulesync generate --targets claudecode --features skills,rules --check",
    "rulesync:fetch": "rulesync fetch kanade0404/skills@v0.8.0 --features skills,rules",
    "rulesync:generate": "rulesync generate --targets claudecode --features skills,rules"
  },
  "type": "module",
  "packageManager": "pnpm@11.9.0"
}
